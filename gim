package switch
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_git_dir();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'switch' );
        ::GetOptions(
            'detach|d' => sub { push( @command, '--detach' ); }
        );
        util::argv_check( 1, 1 );
        push( @command, '--', $ARGV[0] );
        my ( $out, $err, $rc ) = executor::run( \@command );

        if ( $rc == 128 )
        {
            @command = ( 'git', 'rev-parse', $ARGV[0] . '^{commit]' );
            ( $out, $err, $rc ) = executor::run( \@command );

            if ( $rc == 0 )
            {
                util::throw(
                    util::localize( '‘[_1]’ is a commit, not a branch. Forgot ‘--detach’?', $ARGV[0] ) .
                    util::localize( 'Try ‘[_1]’.', 'gim help switch' )
                );
            }
        }

        if ( $rc != 0 )
        {
            util::throw(
                util::localize( 'Failure while executing ‘[_1]’.', 'gim switch' ) .
                util::localize( '‘[_1]’ returned ‘[_2]’:', 'gim switch', $rc ) .
                $err . "\n"
            );
        }

        dbg::leave();
        return;
    }

