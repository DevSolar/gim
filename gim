###################################################################
package dbg
{
    my $_dbg;
    my $_indent = 0;
    my $_t0 = [Time::HiRes::gettimeofday];

    # Called from top-level GetOptions() if --debug is specified.
    # Opens file handle $_dbg to write to gim.log.
    sub init ( $, $ )
    {
        if ( ! open( $_dbg, '>', 'gim.log' ) )
        {
            util::throw(
                util::localize( 'Could not open ‘[_1]’.', 'gim.log' ) .
                $!
            );
        }

        return;
    }

    # Get a high-resolution timestamp (so gim.log tells how long
    # operations are taking).
    sub timestamp
    {
        return sprintf( '%07.4f', Time::HiRes::tv_interval( $_t0 ) );
    }

    # Track entry into a subroutine
    sub enter
    {
        if ( defined( $_dbg ) )
        {
            # Using caller() in  DB puts arguments in @DB::args
            package DB;
            my $package  = caller( 0 );
            my $function = ( caller( 1 ) )[3];

            if ( $package eq 'main' )
            {
                $function = substr( $function, length( 'main::' ) );
            }
            elsif ( $package->isa( 'worker' )
                && substr( $function, -length( 'new' ) ) ne 'new' )
            {
                shift( @DB::args );
            }

            my $msg = sprintf( '%s %s>> %s(', dbg::timestamp(), ( ' ' x $_indent ), $function );

            if ( scalar( @DB::args ) && ref( $DB::args[0] ) ne 'GLOB' )
            {
                $msg .= sprintf( ' %s ',
                    join(
                        ', ',
                        map
                        {
                            defined( $_ )
                                ? ( Scalar::Util::looks_like_number( $_ )
                                    ? $_
                                    : ( ( ( Scalar::Util::reftype( $_ ) // '' ) eq 'ARRAY' )
                                        ? "( '" . join( "', '", @{$_} ) . "' )"
                                        : ( ( ( Scalar::Util::reftype( $_ ) // '' ) eq 'HASH' )
                                            ? "SELF"
                                            : qq('$_')
                                        )
                                    )
                                )
                                : '<undef>'
                        } @DB::args
                    )
                );
            }

            $msg .= ')';
            $_indent += 3;
            $msg =~ s/\n/\\n/g;
            say( {$_dbg} $msg );
        }

        return;
    }

    # Write a message into gim.log
    sub msg ( $msg )
    {
        if ( defined( $_dbg ) )
        {
            for ( split( /\n/, $msg ) )
            {
                say( {$_dbg} timestamp() . ' ' . ( ' ' x $_indent ) . $_ );
            }
        }

        return;
    }

    # Track the leaving of a subroutine
    sub leave
    {
        if ( defined( $_dbg ) )
        {
            $_indent -= 3;
        }

        return;
    }

    # Track the throwing of an exception
    sub throw
    {
        $_indent = 0;
        dbg::msg( '<<<<<' );
        return;
    }

    # Close $_dbg on program exit
    END
    {
        if ( defined( $_dbg ) && fileno( $_dbg ) )
        {
            dbg::msg( 'dbg::END' );
            if ( ! close( $_dbg ) )
            {
                util::throw(
                    util::localize( 'Could not close ‘[_1]’.', 'gim.log' ) .
                    $!
                );
            }
        }

        return;
    }
}

