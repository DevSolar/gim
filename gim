#!/usr/bin/perl

use v5.20;

use strict;
use warnings;
no warnings qw( experimental::signatures );

use utf8;
use feature qw( signatures );
use open    qw( :std :locale );
use autodie qw( close );

our $VERSION = v0.0.22;

use Config          qw( %Config );
use File::Path      qw( make_path );
use Getopt::Long    qw( :config posix_default permute pass_through auto_version );
use IPC::Open3      qw( open3 );
use Scalar::Util    qw( looks_like_number reftype );
use Symbol          qw( gensym );
use Term::ANSIColor qw( colored coloralias colorstrip );
use Text::Wrap;
use Time::HiRes     qw( gettimeofday tv_interval );

use constant CONFIG_DIR => $ENV{ HOME } . '/.config/gim/';
use constant CONFIG_FILE => CONFIG_DIR . 'config.ini';
use constant PACKAGE_DIR => CONFIG_DIR . 'perl5/';

BEGIN
{
    local $@ = '';
    make_path( CONFIG_DIR );

    # Gim relies on Capture::Tiny, which however is not available on all
    # target platforms (most notably Git Bash on Windows). Unfortunately
    # this platform _also_ lacks the infrastructure to pull the package
    # from CPAN. So we do it manually.
    my $rc = eval
    {
        # Check if package is already available
        require Capture::Tiny;
        Capture::Tiny->import( qw( :all ) );
        1;
    };

    if ( ! $rc )
    {
        # Pull package from GitHub to ~/.config/gim.
        make_path( PACKAGE_DIR . 'Capture' );
        system( 'curl https://raw.githubusercontent.com/dagolden/Capture-Tiny/master/lib/Capture/Tiny.pm -s > ' . PACKAGE_DIR . 'Capture/Tiny.pm' );
        use lib PACKAGE_DIR;
        require Capture::Tiny;
        Capture::Tiny->import( qw( :all ) );
        1;
    }

    $rc = eval
    {
        require Config::IniFiles;
        Config::IniFiles->import();
        1;
    };

    if ( ! $rc )
    {
        make_path( PACKAGE_DIR . 'Config' );
        system( 'curl https://raw.githubusercontent.com/shlomif/perl-Config-IniFiles/master/config-inifiles/lib/Config/IniFiles.pm -s > ' . PACKAGE_DIR . 'Config/IniFiles.pm' );
        use lib PACKAGE_DIR;
        require Config::IniFiles;
        Config::IniFiles->import();
        1;
    }

    if ( exists( $ENV{ CLICOLOR } ) && $ENV{ CLICOLOR } == 0 )
    {
        if ( ! $ENV{ CLICOLOR_FORCE } )
        {
            $ENV{ ANSI_COLORS_DISABLED } = 1;
        }
    }
}

