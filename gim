        else
        {
            if ( grep { /^$ARGV[0]$/ } @heads )
            {
                util::throw(
                    util::localize( 'Rewrite from HEAD requires detached commit argument.' )
                );
            }

            $from = $ARGV[0];
        }

        $ENV{ 'GIT_SEQUENCE_EDITOR' } = 'sed -i -e "1 s/pick/drop/"';

        @command = ( 'git', 'rebase', '-i', $from );
