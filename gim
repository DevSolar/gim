###################################################################
# Base class for gim subcommands.
package worker
{
    sub new ( $class )
    {
        dbg::enter();
        my $self = bless( { name => $class }, $class );

        if ( $self->can( 'init' ) )
        {
            $self->init();
        }

        dbg::leave();
        return $self;
    }

    sub init_git_dir ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'rev-parse', '--git-dir' );
        ( $self->{ git_dir }, my $err, my $rc ) = executor::run( \@command );
        dbg::leave();
        return;
    }

    sub init_pager ( $self )
    {
        dbg::enter();

        $Text::Wrap::columns = ( `tput cols 2> /dev/null` || 76 );

        if ( -t STDOUT || -t STDERR )
        {
            open( $self->{ pager }, '|-', 'less -FeRXS' ) || die;
        }

        if ( -t STDOUT )
        {
            open( $self->{ out }, '>&', $self->{ pager } ) || die;
            $self->{ out_paged } = 1;
        }
        else
        {
            $ENV{ 'ANSI_COLORS_DISABLED' } = 1;
            $self->{ out } = \*STDOUT;
        }

        if ( -t STDERR )
        {
            open( $self->{ err }, '>&', $self->{ pager } ) || die;
            $self->{ err_paged } = 1;
        }
        else
        {
            $self->{ err } = \*STDERR;
        }

        dbg::leave();
        return;
    }

    DESTROY
    {
        my ( $self ) = @_;

        if ( defined( $self->{ out_paged } ) )
        {
            close( $self->{ out } );
        }

        if ( defined( $self->{ err_paged } ) )
        {
            close( $self->{ err } );
        }

        if ( defined( $self->{ pager } ) )
        {
            close( $self->{ pager } );
        }

        return;
    }
}

###################################################################
package add
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_pager();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        util::filespec_check( 'FILEORDIR', @ARGV );
        # '--intent-to-add' in combination with 'commit --all'
        # effectively removes staging from the workflow.
        # '--no-all' avoids filesystem deletions resulting in
        # removal from version control, which was considered
        # surprising (a.k.a. 'bad').
        my @command = ( 'git', 'add', '--intent-to-add', '--no-all', '--', @ARGV );
        executor::run( \@command );
        dbg::leave();
        return;
    }

$_help{ add } =
{
    category => q{local},
    about => q{Add files to version control},
    usage => q{gim add <filespec> [<filespec> ...]
},
    help => q{Add files to version control.

Earmarks previously untracked files to be included in the next
commit, thereby adding them to version control.

Directories specified as arguments will be added including their
contents, recursively. Adding an empty directory does nothing (as
Git does not store empty directories), but does not generate an
error either.
},
    impl => q{git add --intent-to-add --no-all -- [...]
}};

}

###################################################################
package bisect
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_git_dir();
