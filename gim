package pick
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_status();
        $self->init_ahead_behind();
        util::filespec_check( 'TRACKED', @ARGV );
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();

        my $force;
        ::GetOptions(
            'force|f' =>\$force
        );

        if ( ! $force )
        {
            util::throw(
                util::localize( 'The ‘pick’ command overwrites local modifications. Use ‘-f’/‘--force’ to confirm.' )
            );
        }

        if ( $self->{ 'branch.head' } eq '(detached)' )
        {
            util::throw(
                util::localize( 'Repository in “detached HEAD” state, cannot pick.' )
            );
        }

        if ( ! defined( $self->{ 'branch.upstream' } ) )
        {
            util::throw(
                util::localize( 'No upstream defined.' )
            );
        }

        if ( $self->{ 'branch.behind' } <= 0 )
        {
            print( {$self->{ out }}
                util::localize( 'No unmerged changes.' )
            );
        }
        else
        {
            my @command = ();

            @command = ( 'git', 'restore', '--source=@{u}', '--', @ARGV );
            executor::run( \@command );
        }

        dbg::leave();
        return;
    }

