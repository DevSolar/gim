            "\n\n" .
            Text::Wrap::fill( ' ', ' ', $_topic{ $topic }{ help } )
        );
        dbg::leave();
        return;
    }

    sub help_on_command ( $self, $command )
    {
        dbg::enter();
        print( {$self->{ out }}
            "\n" .
            ' ' . fmt::header( util::localize( 'Usage:' ) ) .
            '   ' . $_help{ $command }{ usage } .
            "\n" .
            Text::Wrap::fill( ' ', ' ', $_help{ $command }{ help } )
        );

        if ( $cfg->val( 'options', 'impl_info' ) eq '1' )
        {
            print( {$self->{ out }}
                "\n\n" .
                ' ' . fmt::header( util::localize( 'Implementation:' ) ) .
                "\n" .
                Text::Wrap::fill( ' ', ' ', $_help{ $command }{ impl } )
            );
        }

        dbg::leave();
        return;
    }

