# Base class for gim subcommands.
package worker
{
    sub new ( $class )
    {
        dbg::enter();
        my $self = bless( { name => $class }, $class );

        if ( $self->can( 'init' ) )
        {
            $self->init();
        }

        dbg::leave();
        return $self;
    }

    sub init_git_dir ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'rev-parse', '--git-dir' );
        ( $self->{ git_dir }, my $err, my $rc ) = executor::run( \@command );
        dbg::leave();
        return;
    }

    sub init_status ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'status', '--porcelain=2', '--branch', '--show-stash' );
        my $exe = executor->new( \@command );
        my @status = ();

        while ( $exe->readln() )
        {
            if ( m/^# ([^ ]*) (.*)/ )
            {
                $self->{ $1 } = $2;
            }
            else
            {
                push( @status, $_ );
            }
        }

        $exe->close_exe();
        $self->{ 'status' } = \@status;
        dbg::leave();
        return;
    }

    sub init_ahead_behind ( $self )
    {
        dbg::enter();
        $self->{ 'branch.ahead' } = -1;
        $self->{ 'branch.behind' } = -1;

        if ( defined( $self->{ 'branch.ab' } ) )
        {
            if ( $self->{ 'branch.ab' } =~ m/\+(\d*) -(\d*)/ )
            {
                $self->{ 'branch.ahead' } = $1;
                $self->{ 'branch.behind' } = $2;
            }
        }

        dbg::leave();
        return;
    }

    sub init_pager ( $self )
    {
        dbg::enter();

        $Text::Wrap::columns = ( `tput cols 2> /dev/null` || 76 );

        if ( -t STDOUT || -t STDERR )
        {
            open( $self->{ pager }, '|-', 'less -FeRXS' ) || die;
        }

        if ( -t STDOUT )
        {
            open( $self->{ out }, '>&', $self->{ pager } ) || die;
            $self->{ out_paged } = 1;
        }
        else
        {
            $ENV{ ANSI_COLORS_DISABLED } = 1;
            $self->{ out } = \*STDOUT;
        }

        if ( -t STDERR )
        {
            open( $self->{ err }, '>&', $self->{ pager } ) || die;
            $self->{ err_paged } = 1;
        }
        else
        {
            $self->{ err } = \*STDERR;
        }

        dbg::leave();
        return;
    }

    sub init_tracking( $self )
    {
        dbg::enter();
        my @command = ( 'git',  'rev-parse', '--abbrev-rev', '@{u}' );
        my ( $out, $err, $rc ) = executor::run( \@command, throw_on_fail => 0 );
        $self->{ tracking } = $rc;
        dbg::leave();
        return;
    }

    sub init_history ( $self, $count )
    {
        dbg::enter();

        # Get an array of the hashes of commits from HEAD
        my @history = ();
        my @command = ( 'git', 'log', 'HEAD', '-n' . ( $count + 1 ), '--pretty=format:%H' );

        dbg::msg( 'History:' );
        my $exe = executor->new( \@command );

        while ( $exe->readln() )
        {
            chomp;
            dbg::msg( $_ );
            push( @history, $_ );
        }

        $exe->close_exe();
        push( @command, '--not', '--remotes' );
        dbg::msg( 'Unpublished:' );
        $exe = executor->new( \@command );

        while ( $exe->readln() )
        {
            chomp;
            dbg::msg( $_ );
            $self->{ unpublished } = $_;
        }

        $exe->close_exe();
        $self->{ history } = \@history;
        dbg::leave();
        return;
    }

    DESTROY
    {
        my ( $self ) = @_;

        if ( defined( $self->{ out_paged } ) )
        {
            close( $self->{ out } );
        }

        if ( defined( $self->{ err_paged } ) )
        {
            close( $self->{ err } );
        }

        if ( defined( $self->{ pager } ) )
        {
            close( $self->{ pager } );
        }

        return;
    }
}

