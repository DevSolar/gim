package util
{
    # Check that the number of arguments remaining in @ARGV
    # is no less than min and no more than max. -1 means no
    # check.
    sub argv_check ( $min, $max )
    {
        dbg::enter();

        if ( @ARGV < $min )
        {
            util::throw(
                util::localize( 'Too few arguments.' ) .
                util::localize( 'Try ‘[_1]’.', 'gim help ' . caller( 0 ) )
            );
        }

        if ( ( $max > -1 ) && ( @ARGV > $max ) )
        {
            util::throw(
                util::localize( 'Too many arguments.' ) .
                util::localize( 'Try ‘[_1]’.', 'gim help ' . caller( 0 ) )
            );
        }

        dbg::leave();
        return;
    }

    # Configuration defaults, if no config.ini is found.
    sub cfg_defaults
    {
        dbg::enter();
        my $defaults = Config::IniFiles->new();

        $defaults->AddSection( 'colorscheme' );
        $defaults->newval( 'colorscheme', 'branch',   'green' );
        $defaults->newval( 'colorscheme', 'current',  'cyan' );
        $defaults->newval( 'colorscheme', 'error',    'red' );
        $defaults->newval( 'colorscheme', 'hash',     'yellow' );
        $defaults->newval( 'colorscheme', 'header',   'bold' );
        $defaults->newval( 'colorscheme', 'line',     'magenta' );
        $defaults->newval( 'colorscheme', 'local',    'green' );
        $defaults->newval( 'colorscheme', 'name',     'cyan' );
        $defaults->newval( 'colorscheme', 'ok',       'green' );
        $defaults->newval( 'colorscheme', 'push',     'blue' );
        $defaults->newval( 'colorscheme', 'ref',      'cyan' );
        $defaults->newval( 'colorscheme', 'remote',   'red' );
        $defaults->newval( 'colorscheme', 'stash',    'yellow' );
        $defaults->newval( 'colorscheme', 'symref',   'green' );
        $defaults->newval( 'colorscheme', 'tag',      'yellow' );
        $defaults->newval( 'colorscheme', 'time',     'blue' );
        $defaults->newval( 'colorscheme', 'upstream', 'yellow' );
        $defaults->newval( 'colorscheme', 'url',      'magenta' );
        $defaults->newval( 'colorscheme', 'warn',     'yellow' );

        $defaults->AddSection( 'options' );
        $defaults->newval( 'options', 'impl_info', '0' );
        $defaults->newval( 'options', 'hash_length', '8' );
        $defaults->newval( 'options', 'graph_width', '6' );
        $defaults->newval( 'options', 'diff', '-U3' );

        dbg::leave();
        return $defaults;
    }

    # Initialize the default configuration, then import config.ini
    # to override defaults. Also, creates color aliases for all
    # entries of [colorscheme].
    sub cfg_read
    {
        dbg::enter();

        # If config.ini does not exist, create empty config.ini.
        # (Config::IniFiles->new() can handle empty file, but not
        # non-existing file.)
        if ( ! -e ::CONFIG_FILE )
        {
            my $cfgfile;

            if ( ! open( $cfgfile, '>', ::CONFIG_FILE ) )
            {
                util::throw(
                    util::localize( 'Could not open ‘[_1]’.', ::CONFIG_FILE ) .
                    $!
                );
            }

            close( $cfgfile );
        }

        # Initialize defaults, load config.ini
        my $config = Config::IniFiles->new( -import => util::cfg_defaults(), -file => ::CONFIG_FILE, -allowempty => 1 );

        # Aliassing colorscheme settings
        foreach ( $config->Parameters( 'colorscheme' ) )
        {
            dbg::msg( "coloralias( '$_', '$config->val( 'colorscheme', $_ )' )" );
            ::coloralias( $_, $config->val( 'colorscheme', $_ ) );
        }

        dbg::leave();
        return $config;
    }

    # Check if the list of arguments violates the predicate
    # given as first parameter. Returns if all arguments
    # check out, throws otherwise.
    # Predicates:
    # FILE, FILEORDIR, TRACKED
    sub filespec_check ( $predicate, @filespec )
    {
        dbg::enter();

        foreach ( @filespec )
        {
            if ( ! -e $_ )
            {
                util::throw(
                    util::localize( '‘[_1]’ does not exist.', $_ )
                );
            }

            if ( ( $predicate eq 'FILE' ) && ( ! -f $_ ) )
            {
                util::throw(
                    util::localize( '‘[_1]’ is not a regular file.', $_ )
                );
            }

            if ( ( $predicate eq 'FILEORDIR' ) && ( ( ( ! -f $_ ) && ( ! -d $_ ) ) || -l $_ ) )
            {
                util::throw(
                    util::localize( '‘[_1]’ is neither regular file nor directory.', $_ )
                );
            }

            if ( $predicate eq 'TRACKED' )
            {
                my @command = ( 'git', 'ls-files', '--error-unmatch', $_ );
                my ( $out, $err, $rc ) = executor::run( \@command, throw_on_fail => 0 );

                if ( $rc != 0 )
                {
                    util::throw(
                        util::localize( '‘[_1]’ is not under version control.', $_ )
                    );
                }
            }
        }

        dbg::leave();
        return;
    }

    # Given a basic message and a list of arguments, this function
    # inserts arguments in place of placeholders '[_1]', '[_2]'
    # etc. in the basic message.
    sub localize ( $msg, @args )
    {
        dbg::enter();

        # Replace ‘[_n]’ with argument #n - 1.
        for ( 1 .. @args )
        {
            $msg =~ s/\[_$_\]/$args[ $_ - 1 ]/;
        }

        dbg::msg( $msg );
        dbg::leave();
        return $msg . "\n";
    }

    sub rc_check ( $rc, $command, $err, %options )
    {
        dbg::enter();

        my %opts = ( throw_on_fail => 1, %options );

        if ( $rc != 0 )
        {
            if ( $rc == -1 )
            {
                util::throw(
                    util::localize( 'Could not execute ‘[_1]’.', ${$command}[0] ) .
                    $err .
                    "\n"
                );
            }

            if ( $rc & 127 )
            {
                util::throw(
                    util::localize( 'Child process died with signal [_1] ‘SIG[_2]’.', $rc, $sig_names[ $rc ] )
                );
            }

            $rc >>= 8;

            if ( $opts{ throw_on_fail } )
            {
                util::throw(
                    util::localize( 'Failure while executing ‘[_1]’.', ${$command}[0] . ' ' . ${$command}[1] ) .
                    $err .
                    "\n"
                );
            }
        }

        dbg::leave();
        return $rc;
    }

    # Pull subcommand from @ARGV.
    # When called from the top level, checks existence of worker
    # class by that name, and returns an instance of that class.
    # When called from a worker class, checks for a function by
    # that name, and returns the name.
    sub subcommand ( $default, %aliases )
    {
        dbg::enter();
        my $caller = caller( 0 );
        my $subcommand;

        if ( @ARGV )
        {
            my $candidate = $aliases{ $ARGV[0] } // $ARGV[0];

            if ( $caller eq 'main' )
            {
                if ( $candidate->isa( 'worker' ) && ! ( $candidate =~ m/worker$/ ) )
                {
                    $subcommand = $candidate;
                    shift( @ARGV );
                }
            }
            else
            {
                if ( $caller->can( $candidate ) )
                {
                    $subcommand = $candidate;
                    shift( @ARGV );
                }
            }

            if ( ! defined( $subcommand ) )
            {
                util::throw( util::localize( 'Unknown command.' ) );
            }
        }
        elsif ( ! defined( $subcommand ) )
        {
            $subcommand = $default;
        }

        if ( $caller eq 'main' )
        {
            $subcommand = $subcommand->new();
        }

        dbg::leave();
        return $subcommand;
    }

    # Throw exception: rc as the error code, msg as exception
    # message.
    sub throw ( $msg )
    {
        $msg = fmt::error( $msg );
        dbg::throw();
        local $! = $E_ERROR;
        die( $msg );
    }
}

