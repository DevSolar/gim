package push
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_status();

        if ( $self->{ 'branch.head' } eq '(detached)' )
        {
            util::throw(
                util::localize( 'Operation not possible in unnamed branch.' )
            );
        }

        if ( $self->{ 'branch.oid' } eq '(initial)' )
        {
            util::throw(
                util::localize( 'Operation not possible in initial state.' )
            );
        }

        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'push', '--follow-tags', '--quiet' );
        my $remote;
        my $force;
        ::GetOptions(
            'to|t=s' => \$remote,
            'force|f' => sub { push( @command, '--force-with-lease' ); }
        );

        my @helper_command = ( 'git', 'for-each-ref', '--format=%(push:lstrip=2)', 'refs/heads/' . $self->{ 'branch.head' } );
        my ( $push, $err, $rc ) = executor::run( \@helper_command );
        chomp $push;

        if ( $push eq '' )
        {
            if ( ! defined( $remote ) )
            {
                util::throw(
                    util::localize( 'No remote to push to.' )
                );
            }

            @helper_command = ( 'git', 'branch', '--remotes', '--list', '--format=%(refname:lstrip=3)', $remote . '/*' );
            ( my $out, $err, $rc ) = executor::run( \@helper_command );
            my @remote_branches = split( "\n", $out );

            if ( scalar( @remote_branches ) == 0 )
            {
                util::throw(
                    util::localize( 'Unknown remote ‘[_1]’.', $remote )
                );
            }

            if ( grep { /^$self->{ 'branch.head' }$/ } @remote_branches )
            {
                util::throw(
                    util::localize( 'Branch ‘[_1]’ already exists on remote ‘[_2]’.', $self->{ 'branch.head' }, $remote )
                );
            }

            push( @command, ( '--set-upstream', $remote, $self->{ 'branch.head' } ) );
        }

        executor::run( \@command );
        dbg::leave();
        return;
    }

