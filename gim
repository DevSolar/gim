package fmt
{
    sub branch ( $str )
    {
        return ::colored( sprintf( '%-20s', $str ), substr( $str, 0, 1 ) eq '*' ? 'current' : 'branch' );
    }

    sub description ( $str )
    {
        return $str;
    }

    sub error ( $str )
    {
        return ::colored( util::localize( 'Error:' ), 'error' ) . ' ' . $str;
    }

    sub graph ( $str )
    {
        my $len = length( ::colorstrip( $str ) );
        my $width = $cfg->val( 'options', 'graph_width' );

        if ( $len < $width )
        {
            $str .= ( ' ' x ( $width - $len ) );
        }

        return ' ' . $str;
    }

    sub hash ( $str )
    {
        return ::colored( $str, 'hash' );
    }

    sub header ( $str )
    {
        return ::colored( $str, 'header' );
    }

    sub linenr ( $str )
    {
        return ::colored( $str, 'line' );
    }

    sub local ( $str )
    {
        return ::colored( sprintf( '  %-20s', $str ), 'local' );
    }

    sub name ( $str )
    {
        return ::colored( sprintf( '%-15.15s', $str ), 'name' );
    }

    sub ok ( $str )
    {
        return ::colored( util::localize( 'OK:' ), 'ok' ) . '  ' . $str;
    }

    sub push ( $str )
    {
        return ::colored( $str, 'push' );
    }

    sub ref ( $str )
    {
        return ::colored( $str, 'ref' );
    }

    sub remote ( $str )
    {
        return ::colored( sprintf( '%12s', $str ), 'remote' );
    }

    sub stash ( $str )
    {
        return ::colored( $str, 'stash' );
    }

    sub symref ( $str )
    {
        return ::colored( $str, 'symref' );
    }

    sub tag ( $str )
    {
        return ::colored( $str, 'tag' );
    }

    sub time ( $str )
    {
        return ::colored( sprintf( '%15s', $str ), 'time' );
    }

    sub upstream ( $str )
    {
        return ::colored( $str, 'upstream' );
    }

    sub url ( $str )
    {
        return ::colored( $str, 'url' );
    }

    sub warning ( $str )
    {
        return ::colored( util::localize( 'Warning:' ), 'warn' ) . ' ' . $str;
    }
}

###################################################################
###################################################################
# Similar to worker::execute(), which provides combined stdout and
# stderr of a command in scalar return values, this class gives
# access to stdout of a command line by line (i.e., as a stream).
#
# $self->{ out } is a stream handle on stdout.
# $self->{ err } is a stream handle on stderr.
# $self->{ errors } will receive a dump of $self->{ err } when
# $self->close_exe() is called.
package executor
{
    sub run ( $command, %options )
    {
        dbg::enter();
        my $out = '';
        my $err = '';
        my $rc;

        if ( defined( $options{ 'interactive' } ) )
        {
            $rc = system( @{$command} );
        }
        else
        {
            ( $out, $err, $rc ) = Capture::Tiny::capture { system( @{$command} ); };
        }

        $rc = util::rc_check( $rc, $command, $err, %options );
        dbg::leave();
        return ( $out, $err, $rc );
    }

    # Requires the command to be executed as parameter.
    sub new ( $class, $command )
    {
        dbg::enter();
        my $self = bless( { command => $command, pid => 0, linecount => 0, err => Symbol::gensym }, $class );
        eval
        {
            $self->{ pid } = IPC::Open3::open3( $self->{ in }, $self->{ out }, $self->{ err }, @{$command} );
            1;
        }
        or do
        {
            dbg::msg( 'Exception thrown by open3()' );
            dbg::msg( $@ );
            util::throw(
                util::localize( 'Failure while executing ‘[_1]’.', ${$command}[0] . ' ' . ${$command}[1] ) .
                $! .
                "\n" );
        };

        dbg::leave();
        return $self;
    }

    # Writes a line of output to $_.
    sub readln ( $self )
    {
        dbg::enter();
        use Encode qw( decode );
        my $fh = $self->{ out };

        if ( defined( $_ = decode( 'UTF-8', readline( $fh ) ) ) )
        {
            ++$self->{ 'linecount' };
        }

        dbg::leave();
        return $_;
    }

    # Closes the stream, writing stderr to $self->{ errors }.
    # This is optional, as the destructor will do it anyway.
    sub close_exe ( $self )
    {
        dbg::enter();

        if ( $self->{ pid } != 0 )
        {
            my $fh = $self->{ err };
            $self->{ errors } = do { local $/ = undef; <$fh> };

            if ( length( $self->{ errors } ) > 0 )
            {
                dbg::msg( "Output on stderr: $self->{ errors }" );
            }

            dbg::msg( "waiting for $self->{ pid }" );
            waitpid( $self->{ pid }, 0 );
            $self->{ pid } = 0;
            $self->{ rc } = util::rc_check( $?, $self->{ command }, $self->{ errors } );
        }

        dbg::leave();
        return;
    }

    DESTROY
    {
        my ( $self ) = @_;
        dbg::enter();
        $self->close_exe();
        dbg::leave();
        return;
    }
}

