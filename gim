package purge
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_git_dir();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my $sep = "\x{1f}";
        my @command = ( 'git', 'for-each-ref', 'refs/heads',
            "--format=%(HEAD) %(refname:short)${sep}%(upstream:short)${sep}%(push:short)${sep}%(push:track)" );
        my $exe = executor->new( \@command );
        my @gone = ();
        my $current_gone;

        while ( $exe->readln() )
        {
            chomp;
            my ( $branch, $upstream, $push, $track ) = split( $sep );

            next if $track !~ /\[gone\]/;

            if ( substr( $branch, 0, 1 ) eq '*' )
            {
                $current_gone = substr( $branch, 2 );
            }
            else
            {
                push( @gone, substr( $branch, 2 ) );
            }
        }

        $exe->close_exe();

        if ( defined( $current_gone ) )
        {
            warn( fmt::error(
                util::localize( "Cannot delete current branch \x{2018}[_1]\x{2019}: upstream is gone. Switch to another branch first.", $current_gone )
            ) );
        }

        if ( ! @gone )
        {
            if ( ! defined( $current_gone ) )
            {
                print( util::localize( 'No branches with gone upstream found.' ) );
            }

            dbg::leave();
            return;
        }

        foreach my $branch ( @gone )
        {
            @command = ( 'git', 'branch', '--delete', '--force', '--', $branch );
            executor::run( \@command, interactive => 1 );
        }

        dbg::leave();
        return;
    }

