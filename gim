# Base class for gim subcommands.
package worker
{
    sub new ( $class )
    {
        dbg::enter();
        my $self = bless( { name => $class }, $class );

        if ( $self->can( 'init' ) )
        {
            $self->init();
        }

        dbg::leave();
        return $self;
    }

    sub init_pager ( $self )
    {
        dbg::enter();

        $Text::Wrap::columns = ( `tput cols 2> /dev/null` || 76 );

        if ( -t STDOUT || -t STDERR )
        {
            open( $self->{ pager }, '|-', 'less -FeRXS' ) || die;
        }

        if ( -t STDOUT )
        {
            open( $self->{ out }, '>&', $self->{ pager } ) || die;
            $self->{ out_paged } = 1;
        }
        else
        {
            $self->{ out } = \*STDOUT;
        }

        if ( -t STDERR )
        {
            open( $self->{ err }, '>&', $self->{ pager } ) || die;
            $self->{ err_paged } = 1;
        }
        else
        {
            $self->{ err } = \*STDERR;
        }

        dbg::leave();
        return;
    }

    DESTROY
    {
        my ( $self ) = @_;

        if ( defined( $self->{ out_paged } ) )
        {
            close( $self->{ out } );
        }

        if ( defined( $self->{ err_paged } ) )
        {
            close( $self->{ err } );
        }

        if ( defined( $self->{ pager } ) )
        {
            close( $self->{ pager } );
        }

        return;
    }
}

###################################################################
package help
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_pager();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my $subject = 'help';

        if ( @ARGV == 0 || $ARGV[0] eq 'topics' )
        {
            $self->help();
        }
        else
        {
            $subject = shift( @ARGV );

            if ( defined( $_topic{ $subject } ) )
            {
                $self->help_on_topic( $subject );
            }
            elsif ( defined( $_help{ $subject } ) )
            {
                $self->help_on_command( $subject );
            }
            else
            {
                util::throw(
                    util::localize( 'No help available for ‘[_1]’.', $subject )
                );
            }
        }

        dbg::leave();
        return;
    }

    sub help ( $self )
    {
        dbg::enter();
        print( {$self->{ out }}
            "\n" .
            ' ' . util::localize( 'Usage:' ) .
            ( ( @ARGV == 0 ) ? "   gim help <subcommand>\n" : "" ) .
            "   gim help <topic>\n\n" .
            ( ( @ARGV == 0 ) ? ' ' . util::localize( 'Available subcommands:' ) . "\n" : "" )
        );

        if ( @ARGV == 0 )
        {
            # List each category in their sort order
            foreach my $category ( sort { $_category{ $a }{ order } <=> $_category{ $b }{ order } } keys %_category )
            {
                print( {$self->{ out }}
                    '   ' . util::localize( $_category{ $category }{ about } )
                );

                # List the commands alphabetically
                foreach my $command ( sort keys %_help )
                {
                    # Filter for commands of the current category
                    if ( $_help{ $command }{ category } eq $category )
                    {
                        printf( {$self->{ out }}
                            "     gim %-19s %s\n", $command, $_help{ $command }{ about }
                        );
                    }
                }

                print( {$self->{ out }} "\n" );
            }
        }

        print( {$self->{ out }}
            ' ' . util::localize( 'Available topics:' ) .
            "\n"
        );

        foreach my $topic ( sort { $_topic{ $a }{ order } <=> $_topic{ $b }{ order } } keys %_topic )
        {
            printf( {$self->{ out }}
                "     %-23s %s\n", $topic, $_topic{ $topic }{ about }
            );
        }

        dbg::leave();
        return;
    }

    sub help_on_topic ( $self, $topic )
    {
        dbg::enter();
        print( {$self->{ out }}
            "\n" .
            ' ' . $_topic{ $topic }{ about } .
            "\n\n" .
            Text::Wrap::fill( ' ', ' ', $_topic{ $topic }{ help } )
        );
        dbg::leave();
        return;
    }

    sub help_on_command ( $self, $command )
    {
        dbg::enter();
        print( {$self->{ out }}
            "\n" .
            ' ' . util::localize( 'Usage:' ) .
            '   ' . $_help{ $command }{ usage } .
            "\n" .
            Text::Wrap::fill( ' ', ' ', $_help{ $command }{ help } )
        );

        dbg::leave();
        return;
    }

$_help{ help } =
{
    category => q{info},
    about => q{Help system},
    usage => q{gim help [<subject>]
},
    help => q{Gim help system.

Gim does not come with separate documentation, but its own help
system.

With ‘gim help’ you get an overview of available subcommands and
help topics.

With ‘gim help <subject>’ you get help on a specific subject, which
can be either a subcommand, or a general help topic (which are not
linked to any specific subcommand).
}};

}

