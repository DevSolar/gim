package blame
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_pager();
        $self->init_git_dir();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        util::filespec_check( 'TRACKED', @ARGV );
        my @command = ( 'git', 'blame', @ARGV );
        my $exe = executor->new( \@command );
        my $lasthash = '';
        my $linecol = 0;

        while ( $exe->readln() )
        {
            if ( m/^([[:xdigit:]^]*) (.*)\((.*?) (\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2} .\d{4})( *\d*)\)(.*)/ )
            {
                if ( $1 ne $lasthash )
                {
                    $linecol = ( $linecol ) ? 0 : 1;
                }

                printf( {$self->{ out }}
                    "%s %s%s %s%s)%s\n",
                    fmt::hash( $1 ),
                    $2,
                    fmt::name( $3 ),
                    fmt::time( $4 ),
                    ( $linecol ) ? fmt::linenr( $5 ) : $5,
                    $6
                );

                $lasthash = $1;
            }
            else
            {
                util::throw(
                    util::localize( 'Unexpected output by git:' ) .
                    $_
                );
            }
        }

        $exe->close_exe();
        dbg::leave();
        return;
    }

