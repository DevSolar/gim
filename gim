package log
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_pager();
        $self->init_git_dir();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my $print_graph;
        my @specs = ();
        my $predefined = 0;
        ::GetOptions(
            "all|a" => sub { push( @specs, '--all' ); },
            "short|s" => sub { push( @specs, '--format=short' ); $predefined = 1; },
            "medium|m" => sub { push( @specs, '--format=medium' ); $predefined = 1; },
            "long|l" => sub { push( @specs, '--format=full' ); $predefined = 1; },
            "verbose|v" => sub { push( @specs, '--format=fuller' ); $predefined = 1; },
            "reference|r" => sub { push( @specs, '--format=reference' ); $predefined = 1; },
            "graph|g" => sub { push( @specs, '--graph', '--all' ); $print_graph = 1; }
        );

        push( @specs, @ARGV );
        my $log = logger->new( \@specs );

        while ( $predefined ? $log->readln() : $log->readln_fmt() )
        {
            my $line;

            if ( $predefined )
            {
                # Predefined format, leave alone
                chomp;
                $line = $_ . "\n";
            }
            else
            {
                # Custom format
                if ( scalar( @{$_} ) == 1 )
                {
                    $line = ' ' . ${$_}[0] . "\n";
                }
                else
                {
                    my ( $graph, $hash, $authorName, $authorTimeRel, $authorTimeIso, $commitName, $commitTimeRel, $commitTimeIso, $subject, $description ) = @{$_};
                    $line =
                        ( $print_graph ? fmt::graph( $graph ) : ' ' ) .
                        fmt::hash( $hash ) . '  ' .
                        fmt::time( $authorTimeIso ) . '  ' .
                        fmt::name( $authorName ) . '  ' .
                        $subject . '  ' .
                        fmt::description( $description ) . '  ' .
                        "\n";
                }
            }

            print( {$self->{ out }} $line );
        }

        $log->close_exe();
        dbg::leave();
        return;
    }

