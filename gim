    sub run ( $self )
    {
        dbg::enter();
        my $from;
        my @command = ( 'git', 'for-each-ref', 'refs/heads/*', '--format=%(refname:lstrip=2)' );
        my ( $out, $err, $rc ) = executor::run( \@command );
