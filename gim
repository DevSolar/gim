package stash
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_pager();
        $self->init_status();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my $command = util::subcommand( 'push' );
        $self->$command();
        dbg::leave();
        return;
    }

    sub apply ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'stash', 'apply', @ARGV );
        executor::run( \@command );
        dbg::leave();
        return;
    }

    sub branch ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'stash', 'branch', @ARGV );
        executor::run( \@command );
        dbg::leave();
        return;
    }

    sub clear ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'stash', 'clear', @ARGV );
        executor::run( \@command );
        dbg::leave();
        return;
    }

    sub drop ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'stash', 'drop', @ARGV );
        executor::run( \@command );
        dbg::leave();
        return;
    }

    sub list ( $self )
    {
        dbg::enter();
        printf( {$self->{ out }} ' ' . util::localize( 'Stashed:' ) );

        if ( ! defined( $self->{ stash } ) )
        {
            printf( {$self->{out}} '    ' . fmt::stash( util::localize( 'None' ) ) );
            return;
        }

        my @command = ( 'git', 'stash', 'list', @ARGV );
        my $exe = executor->new( \@command );

        while ( $exe->readln() )
        {
            my ( $id, $branch, $commit, $msg ) = ( m/stash\@\{(.*)\}: WIP on ([^:]*): ([a-f0-9]*) (.*)/ );

            if ( defined( $commit ) )
            {
                $msg = fmt::hash( $commit ) . ' ' . $msg;
            }
            else
            {
                ( $id, $branch, $msg ) = ( m/stash\@\{(.*)\}: On ([^:]*): (.*)/ );
            }

            printf( {$self->{ out }}
                "    %s: %s: %s\n",
                fmt::stash( $id ),
                fmt::branch( $branch ),
                $msg
            );
        }

        $exe->close_exe();
        dbg::leave();
        return;
    }

    sub pop ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'stash', 'pop', @ARGV );
        executor::run( \@command );
        dbg::leave();
        return;
    }

    sub push ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'stash', 'push', '--include-untracked', @ARGV );
        executor::run( \@command );
        dbg::leave();
        return;
    }

    sub show ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'stash', 'show', '--include-untracked', '--patch', @ARGV );
        my $exe = executor->new( \@command );

        while ( $exe->readln() )
        {
            print( {$self->{ out }} $_ );
        }

        $exe->close_exe();
        dbg::leave();
        return;
    }

