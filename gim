        my ( $out, $err, $rc ) = executor::run( \@command );

        my @remotes = split( "\n", $out );

        if ( @ARGV )
        {
            foreach ( @ARGV )
            {
                my $remote = $_;

                if ( ! grep { /^$remote$/ } @remotes )
                {
                    util::throw(
                        util::localize( 'No such remote: ‘[_1]’.', $remote )
                    );
                }

                $self->remote( $remote );
            }
        }
        else
        {
            @command = ( 'git', 'config' );

            foreach ( @remotes )
            {
                $command[2] = 'remote.' . $_ . '.url';
                ( $out, $err, $rc ) = executor::run( \@command );
                chomp( $out );
                printf( {$self->{ out }}
                    " %s  %s\n",
                    fmt::remote( $_ ),
                    fmt::url( $out )
                );
            }

            say( {$self->{ out }} ' ' . ( '-' x ( $Text::Wrap::columns - 2 ) ) );

            $self->overview();
        }

        dbg::leave();
        return;
    }

    sub overview ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'for-each-ref', 'refs/heads', '--format=%(HEAD) %(refname:short)%(upstream:short)%(push:short)%(push:track)' );
        my $exe = executor->new( \@command );

        while ( $exe->readln() )
        {
            chomp;
            my ( $branch, $upstream, $push, $track ) = split( '' );

            if ( $push ne '' && $push eq $upstream )
            {
                $push = '';
            }

            print( {$self->{ out }} ' ' . fmt::branch( $branch ) );

            if ( $upstream ne '' )
            {
                print( {$self->{ out }} '  ' . ( ( $push eq '' ) ? '<->' : ' < ' ) . '  ' . fmt::upstream( $upstream ) );

                if ( $push ne '' )
                {
                    print( {$self->{ out }} ' > ' . fmt::push( $push ) );
                }

                print( {$self->{ out }} '  ' . fmt::track( $track ) );
            }

            print( {$self->{ out }} "\n" );
        }

        $exe->close_exe();
        dbg::leave();
        return;
    }

    sub remote ( $self, $remote )
    {
        dbg::enter();

        # Remote and URL
        my @command = ( 'git', 'config', "remote.$remote.url" );
        my ( $out, $err, $rc ) = executor::run( \@command );
        chomp $out;
        printf( {$self->{ out }}
            "  %s  %s\n",
            fmt::remote( $remote ),
            fmt::url( $out )
        );

        # Remote Branches
        @command = ( 'git', 'branch', '--remotes', '--list', '--format=%(refname:lstrip=2)%(symref:lstrip=2)', $remote . '/*' );
        my $exe = executor->new( \@command );

        while ( $exe->readln() )
        {
            chomp;
            my ( $ref, $symref ) = map { s/$remote\///r } split( "\x{1f}" );
            print( {$self->{ out }} '    ' . fmt::ref( $ref ) );

            if ( $symref )
            {
                print( {$self->{ out }} '  ->  ', fmt::symref( $symref ) );
            }

            print( {$self->{ out }} "\n" );

            if ( $self->{ verbose } && ! defined( $symref ) )
            {
                my $log = git::log( '--max-count=1', $ref );
                my ( $hash, $time_iso, $time_rel, $name, $msg ) = split( '', $exe->readln() );
                $exe->close_exe();
                printf( {$self->{ out }} '%s  %s  %s',
                    fmt::time( $time_rel ),
                    fmt::name( $name ),
                    $msg
                );
            }
        }

        dbg::leave();
        return;
    }

