package fetch
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_git_dir();
        $self->init_pager();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my $quiet;
        ::GetOptions(
            'quiet|q' => \$quiet
        );

        my @tags;
        my @command = ( 'git', 'for-each-ref', '--format="%(objecttype)%(refname:lstrip=2)%(objectname)"', 'refs/tags/*' );
        my $exe = executor->new( \@command );

        while ( $exe->readln() )
        {
            chomp;
            my ( $type, $name, $hash ) = split( '\x{1f}' );

            if ( $type eq 'commit' )
            {
                dbg::msg( "Saving lightweight tag \"$name $hash\"" );
                push( @tags, "$name $hash" );
            }
        }

        $exe->close_exe();

        dbg::msg( 'Fetching from remote, pruning tags' );
        @command = ( 'git', 'fetch', '--all', '--quiet', '--prune', '--prune-tags' );
        executor::run( \@command );

        foreach ( @tags )
        {
            dbg::msg( "Re-applying lightweight tag \"$_\"" );
            @command = ( 'git', 'tag', $_ );
            executor::run( \@command );
        }

        print( {$self->{ out }} util::localize( 'Local repository up to date.' ) );

        if ( ! defined( $quiet ) )
        {
            $self->init_status();
            $self->init_ahead_behind();
            bless( $self, 'status' );
            local @ARGV = ();
            $self->run();
        }

        dbg::leave();
        return;
    }

