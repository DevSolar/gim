package mkpatch
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        util::argv_check( -1, 1 );
        $self->init_status();
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my @command = ( 'tar', 'czf', $ARGV[0] // 'patch.tgz' );

        foreach ( @{$self->{ 'status' }} )
        {
            my @fields = split( ' ' );
            my $path;

            if ( $fields[0] eq "1" )
            {
                $path = $fields[8];
            }
            elsif ( $fields[0] eq "2" )
            {
                ( $path ) = ( $fields[9] =~ m/^([^\t]*)/ );
            }
            elsif ( $fields[0] eq "u" )
            {
                $path = $fields[10];
            }
            elsif ( $fields[0] eq "?" )
            {
                $path = $fields[1];
            }
            else
            {
                util::throw(
                    util::localize( 'Unexpected output by git:' ) .
                    $_
                );
            }

            push( @command, $path );
        }

        executor::run( \@command, throw_on_fail => 0 );
        dbg::leave();
        return;
    }

