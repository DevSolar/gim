###################################################################
package uncommit
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        my $force;
        my $count;
        ::GetOptions(
            'force|f' => \$force,
            'n=i' => \$count
        );

        if ( ! defined( $count ) )
        {
            $count = 1;
        }

        $self->init_history( $count );
        my @history = @{$self->{ history }};

        if ( defined( $force ) )
        {
            if ( scalar( @{$self->{ history }} ) <= $count )
            {
                util::throw(
                    util::localize( 'Not enough commits to operate on.' )
                );
            }
        }
        else
        {
            my $available = 0;

            if ( defined( $self->{ unpublished } ) )
            {
                foreach ( @history )
                {
                    ++$available;
                    last if $self->{ unpublished } eq $_;
                }
            }

            if ( $available < $count )
            {
                util::throw(
                    util::localize( 'Not enough commits to operate on.' )
                );
            }
        }

        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my @command = ( 'git', 'reset', '--mixed', $self->{ history }[-1] );
        executor::run( \@command );
        dbg::leave();
        return;
    }

$_help{ uncommit } =
