package pull
{
    use parent -norequire => 'worker';

    sub init ( $self )
    {
        dbg::enter();
        $self->init_status();
        $self->init_pager();
        $self->init_tracking();

        if ( $self->{ tracking } )
        {
            util::throw( util::localize( 'Branch ‘[_1]’ is not “tracking”, i.e. has no upstream configured.', $self->{ 'branch.head' } ) );
        }

        $self->{ 'local_modifications' } = ( scalar( @{$self->{ 'status' }} ) > 0 );
        dbg::leave();
        return;
    }

    sub run ( $self )
    {
        dbg::enter();
        my @orig_argv = @ARGV;

        if ( $self->{ 'local_modifications' } )
        {
            bless( $self, 'stash' );
            local @ARGV = ( 'push', '-m', 'gim pull' );
            $self->run();
        }

        bless( $self, 'fetch' );
        local @ARGV = ( '--quiet', @orig_argv );
        $self->run();

        $self->init_status();
        $self->init_ahead_behind();

        if ( $self->{ 'branch.behind' } > 0 )
        {
            print( {$self->{ out }} ' ' . util::localize( 'Incoming commits:' ) );
            bless( $self, 'status' );
            $self->behind();
        }

        print( {$self->{ out }} ' ' . util::localize( 'Merging...' ) );
        bless( $self, 'rebase' );
        @ARGV = ( 'start', '--quiet', @orig_argv );
        $self->run();
        print( {$self->{ out}} ' ' . util::localize( 'Done.' ) );

        if ( $self->{ 'local_modifications' } )
        {
            bless( $self, 'stash' );
            local @ARGV = ( 'pop' );
            my $rc = $self->run();

            if ( $rc )
            {
                print( {$self->{ out }} ' ' . util::localize( 'Re-applying your local changes failed due to collisions.\nThey are preserved on top of the stash.' ) );
            }
        }

        undef $self->{ stash };
        $self->init_status();
        $self->init_ahead_behind();
        bless( $self, 'status' );
        local @ARGV = ();
        $self->run();

        dbg::leave();
        return;
    }

