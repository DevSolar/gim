package logger
{
    use parent -norequire => 'executor';

    sub new ( $class, $logspecs, %opts )
    {
        dbg::enter();
        my @ordering = $opts{ walk_reflogs } ? ( '--walk-reflogs' ) : ( '--date-order' );
        my @command = ( 'git', 'log', '--color=always', '--decorate-refs=HEAD', '--decorate-refs=refs/heads', '--decorate-refs=refs/remotes', '--decorate-refs=refs/stash', '--decorate-refs=refs/tags', @ordering, '--abbrev=' . $cfg->val( 'options', 'hash_length' ), '--pretty=format:%h%aN%ar%ai%cN%cr%ci%s%C(auto)%d', @{$logspecs} );
        my $self = $class->SUPER::new( \@command );
        dbg::leave();
        return $self;
    }

    sub readln_fmt ( $self )
    {
        dbg::enter();

        if ( defined( $self->SUPER::readln() ) )
        {
            chomp;
            # my ( $graph, $hash, $authorName, $authorTimeRel, $authorTimeIso, $commitName, $commitTimeRel, $commitTimeIso, $subject, $description ) = @{$_};
            my @elements = ( $_ );

            if ( m// )
            {
                @elements = ( m/([^]*)([^]*)([^]*)([^]*)([^]*)([^]*)([^]*)([^]*)([^]*)([^]*)/ );
                dbg::msg( "$elements[0]-$elements[1]" );
            }

            $_ = \@elements;
        }

        dbg::leave();
        return $_;
    }
}

